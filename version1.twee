        };


        var churches = [
            {
                name: "Church of San Giovanni in Monte",
                coords: [44.49182, 11.34861],
                title: "ESTASI DI SANTA CECILIA FRA I SANTI PAOLO, GIOVANNI EVANGELISTA, AGOSTINO E MARIA MADDALENA",
                img: "https://raw.githubusercontent.com/YixuanQu/Digital-heritage-and-multimedia/main/img/ESTASI%20DI%20SANTA%20CECILIA%20FRA%20I%20SANTI%20PAOLO%2C%20GIOVANNI%20EVANGELISTA%2C%20AGOSTINO%20E%20MARIA%20MADDALENA.jpg",
                link: "https://pinacotecabologna.cultura.gov.it/opere-darte/estasi-di-santa-cecilia-fra-i-santi-paolo-giovanni-evangelista-agostino-e-maria-maddalena-361" 
            },
            {

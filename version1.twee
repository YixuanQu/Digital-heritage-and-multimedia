:: StoryStylesheet [stylesheet]

tw-story {
    background-color: #f4efe2; 
    background-image: radial-gradient(#fffdf7 1px, transparent 0); 
    background-size: 24px 24px;
    color: #2c3e50; 
    font-family: "Georgia", "Times New Roman", "Cambria", serif;
    font-size: 115%;
    line-height: 1.6;
    

    display: flex;
    flex-direction: column;
    align-items: center;    
    justify-content: flex-start;
    width: 100vw;
    padding: 0;
    margin: 0;
}

tw-passage {
    max-width: 680px; 
    width: 90%;             
    padding: 30px;
    background-color: #ffffff;
    border: 1px solid #dcd5c5; 
    border-top: 4px solid #d4af37; 
    box-shadow: 0 10px 30px rgba(184, 172, 146, 0.25); 
    border-radius: 4px;
    margin-left: auto !important;
    margin-right: auto !important;
    margin-top: 10vh;       
    margin-bottom: 5vh;
}

tw-passage em, tw-passage i {
    color: #7f8c8d;
    font-family: -apple-system, sans-serif; 
    font-size: 0.9em;
}

tw-passage strong, tw-passage b {
    color: #1a252f;
    letter-spacing: 0.05em;
    border-bottom: 1px dashed #d4af37;
    padding-bottom: 2px;
}

tw-link {
    color: #b8860b !important; 
    font-weight: bold;
    text-decoration: none;
    border-bottom: 1px solid rgba(184, 134, 11, 0.4);
    transition: all 0.25s ease-in-out;
    padding: 2px 4px;
}

tw-link:hover {
    color: #ffffff !important;
    background-color: #d4af37; 
    border-radius: 3px;
    box-shadow: 0 2px 8px rgba(212, 175, 55, 0.4);
}

tw-sidebar {
    display: none;
}

.leaflet-popup-content-wrapper {
    background-color: #fffdf7 !important;
    color: #2c3e50 !important;
    border-radius: 4px !important;
    border-left: 4px solid #d4af37 !important; 
    font-family: "Georgia", serif !important;
    box-shadow: 0 3px 10px rgba(0,0,0,0.15) !important;
}
.leaflet-popup-tip {
    background: #fffdf7 !important;
}



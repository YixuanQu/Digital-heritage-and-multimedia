            transform: scale(1.0);
        }
        100% {
            transform: scale(1.25);
        }
    }

    .cecilia-cinema-zoom {
        animation: pureSlowZoom 9.0s cubic-bezier(0.15, 0.85, 0.45, 1) 1.2s forwards;
    }

    @keyframes softHighlightFlash {
        0% {
            opacity: 0;
        }
        30% {
